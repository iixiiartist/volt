DATABASE_URL=postgres://volt:volt@localhost:5432/volt
VOLT_REGISTRY_BASE_URL=https://registry.voltagents.com/v1
VOLT_REGISTRY_TOKEN=

# ── LLM Provider API Keys ──────────────────────────────────────────
# Set at least one. Volt auto-detects available providers at startup.
GROQ_API_KEY=your_groq_key_here
NVIDIA_API_KEY=your_nvidia_key_here
OLLAMA_API_KEY=your_ollama_key_here
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here

# ── Embedding API ──────────────────────────────────────────────────
# Default: NVIDIA NIM. Replace with your own key from https://build.nvidia.com/
EMBEDDING_API_KEY=your_nvidia_api_key_here
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
EMBEDDING_ENDPOINT=https://integrate.api.nvidia.com/v1/embeddings
EMBEDDING_PROVIDER=nvidia

# Local Ollama embeddings (NOT available on Ollama Cloud; use local server only):
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_ENDPOINT=http://127.0.0.1:11434/v1/embeddings
# EMBEDDING_PROVIDER=ollama

# HuggingFace token for downloading ONNX models (cached to ~/.cache/huggingface)
HF_TOKEN=your_hf_token_here

# Deprecated — use EMBEDDING_API_KEY / EMBEDDING_MODEL instead
# KIMI_API_KEY=
# KIMI_EMBEDDING_MODEL=kimi-k2.6-embedding

# you.com API key for web search, research, and contents APIs
# Get yours at https://you.com/platform
YOUCOM_API_KEY=your_youcom_api_key_here

# ── Optional Tool Gating (set to 1 to enable) ──────────────────────
# VOLT_ENABLE_LOCAL_LLM_TOOLS=1    # Enables litertlm, llamacpp, mtp (local inference)
# VOLT_ENABLE_CLI_TOOLS=1          # Enables cli_exec, cli_query (enterprise CLI gateway)
# VOLT_MINIMAL_TOOLS=1             # Disables Charts, PDF, Desktop, Browser tools
# VOLT_BFCL_MODE=1                 # Disables bash, web_search, you_research (benchmark mode)

# ── Local LLM Binary Paths ───────────────────────────────────────
# VOLT_TOOL_BIN_DIR=C:\Users\$USER\.volt\tools\bin

# ── Sandbox / Security ─────────────────────────────────────────────
VOLT_SANDBOX_TIMEOUT_MS=5000
VOLT_SANDBOX_MAX_STDOUT_BYTES=262144
# VOLT_COMMAND_GUARD=false         # Disable bash command guard
# VOLT_ALLOWED_HOSTS=example.com,api.example.com

# ── Routing / Configuration ────────────────────────────────────────
LLM_MODEL=llama-3.1-8b-instant
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL_ROUTES={"custom-model":"https://custom.api/v1"}
# LLM_DEFAULT_PROVIDER=groq
# OLLAMA_HOST=http://127.0.0.1:11434

# ── Telemetry ─────────────────────────────────────────────────────
RUST_LOG=info
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector:4317